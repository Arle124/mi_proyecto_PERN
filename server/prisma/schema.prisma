// ============================================================
// schema.prisma — Sistema de Gestión de Viajes | Novapalma
// Versión: 3.0 (3NF + ACID + Auditoría Forense)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS — Dominio controlado
// ============================================================

enum Role {
  ADMIN
  OPERADOR
}

enum TripType {
  NORMAL
  ESPECIAL
}

enum PaymentType {
  EFECTIVO
  TRANSFERENCIA
  CREDITO
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ============================================================
// USUARIOS — Atomicidad y RBAC (RF01, RF03, RF14)
// ============================================================

model User {
  id               String    @id @default(uuid()) @db.Uuid
  primerNombre     String    @db.VarChar(60)
  segundoNombre    String?   @db.VarChar(60)
  primerApellido   String    @db.VarChar(60)
  segundoApellido  String?   @db.VarChar(60)
  correo           String    @unique @db.VarChar(200)
  password         String    @db.VarChar(255) // Hash bcrypt
  rol              Role      @default(OPERADOR)
  activo           Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Relaciones
  tripsRegistered  Trip[]     @relation("TripRegisteredBy")
  tripsUpdated     Trip[]     @relation("TripUpdatedBy")
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

// ============================================================
// CONDUCTORES — Gestión Normalizada (RF05, RF06)
// ============================================================

model Driver {
  id               String    @id @default(uuid()) @db.Uuid
  cedula           String    @unique @db.VarChar(20)
  primerNombre     String    @db.VarChar(60)
  segundoNombre    String?   @db.VarChar(60)
  primerApellido   String    @db.VarChar(60)
  segundoApellido  String?   @db.VarChar(60)
  telefono         String?   @db.VarChar(20)
  activo           Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  trips            Trip[]

  @@map("drivers")
}

// ============================================================
// VEHÍCULOS — Control de Flota (RF04)
// ============================================================

model Vehicle {
  id        String    @id @default(uuid()) @db.Uuid
  placa     String    @unique @db.VarChar(8)
  modelo    String?   @db.VarChar(100)
  activo    Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips     Trip[]

  @@map("vehicles")
}

// ============================================================
// TARIFAS — Reglas de Negocio (RF09, RF10)
// ============================================================

model RateTariff {
  id           Int       @id @default(autoincrement())
  tipoViaje    TripType  @unique
  valorTon     Decimal   @db.Decimal(12, 2)
  activo       Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@map("rate_tariffs")
}

// ============================================================
// VIAJES — Núcleo Transaccional (RF07–RF13)
// ============================================================

model Trip {
  id               String      @id @default(uuid()) @db.Uuid
  ticket           String      @unique @db.VarChar(50)
  fecha            DateTime
  origen           String      @db.VarChar(150)
  tipoViaje        TripType
  tipoPago         PaymentType @default(EFECTIVO)

  tonelaje         Decimal     @db.Decimal(10, 3)
  valorPago        Decimal     @db.Decimal(12, 2)
  consumoAcpm      Decimal?    @db.Decimal(8, 3)
  usoFerry         Boolean     @default(false)

  // Relaciones
  driverId         String      @db.Uuid
  driver           Driver      @relation(fields: [driverId], references: [id])
  vehicleId        String      @db.Uuid
  vehicle          Vehicle     @relation(fields: [vehicleId], references: [id])

  // Trazabilidad Directa (Auditoría Rápida)
  registradoPorId  String      @db.Uuid
  registradoPor    User        @relation("TripRegisteredBy", fields: [registradoPorId], references: [id])
  actualizadoPorId String?     @db.Uuid
  actualizadoPor   User?       @relation("TripUpdatedBy", fields: [actualizadoPorId], references: [id])

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?   // Soft Delete (RF12)

  // Índices optimizados para reportes mensuales y filtrado
  @@index([fecha])
  @@index([deletedAt])
  @@index([driverId, fecha])
  @@index([vehicleId, fecha])

  @@map("trips")
}

// ============================================================
// AUDITORÍA FORENSE — Inmutable (RF15)
// ============================================================

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid
  user       User?       @relation(fields: [userId], references: [id])

  action     AuditAction
  entity     String      @db.VarChar(50)  // Ej: "Trip"
  entityId   String?     @db.VarChar(100)

  oldValues  Json?       // Snapshot anterior
  newValues  Json?       // Snapshot nuevo

  ipAddress  String?     @db.VarChar(45)
  userAgent  String?     @db.VarChar(500)
  createdAt  DateTime    @default(now())

  @@index([entity, entityId])
  @@index([createdAt])

  @@map("audit_logs")
}

// ============================================================
// SESIONES — Seguridad (RNF01)
// ============================================================

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(512)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
